#!/bin/bash

# archy:summary=Install Heroic Games Launcher (Epic, GOG, Amazon Prime Gaming) with graphics drivers.
# archy:requires-sudo=true

set -e

echo "Installing Heroic Games Launcher..."
archy-pkg-add heroic-games-launcher-bin
archy-install-gaming-gpu-lib32

setsid gtk-launch heroic >/dev/null 2>&1 &
