#!/bin/bash

# archy:summary=Remove Voxtype dictation and its configuration
# archy:requires-sudo=true

set -e

# Remove voxtype and its configurations.

if archy-cmd-present voxtype; then
  echo "Uninstall Voxtype to remove dictation."

  # Remove services
  systemctl --user disable --now voxtype.service 2>/dev/null || true
  systemctl --user daemon-reload

  # Remove packages and configs
  archy-pkg-drop voxtype-bin
  rm -rf ~/.config/voxtype
  rm -rf ~/.local/share/voxtype
  archy-hyprland-toggle voxtype off
else
  echo "Voxtype was not installed."
fi
