#!/bin/bash

# archy:summary=Prompt for text input with Walker
# archy:group=menu
# archy:name=input
# archy:args=prompt [walker args...]
# archy:examples=archy menu input Reminder|archy-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

archy-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
