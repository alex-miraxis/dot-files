#!/bin/bash

# archy:summary=Install AUR packages (PKGBUILD review when interactive; non-interactive without a TTY)
# archy:args=<packages...>

if archy-pkg-missing "$@"; then
  if [[ -n ${ARCHY_AUR_TRUST:-} || ! -t 0 ]]; then
    # Trusted, or no TTY to review on (e.g. the logged installer, which runs
    # every step with stdin from /dev/null). Build the pre-vetted list fully
    # non-interactively: --noconfirm plus explicit menu answers so yay can never
    # stop on its clean/diff/edit prompts. See SECURITY.md.
    yay -S --needed --noconfirm \
      --answerclean=None --answerdiff=None --answeredit=None --removemake "$@" || exit 1
  else
    # Interactive: review each PKGBUILD/.install + upstream diff before building.
    yay -S --needed "$@" || exit 1
  fi
fi

for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
