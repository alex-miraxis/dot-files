#!/bin/bash

# archy:summary=Install AUR packages (PKGBUILD review when interactive; auto-skips when there's no TTY)
# archy:args=<packages...>

if archy-pkg-missing "$@"; then
  if [[ -n ${ARCHY_AUR_TRUST:-} || ! -t 0 ]]; then
    # Explicitly trusted, OR no TTY to review on (e.g. the logged installer,
    # which runs every step with stdin from /dev/null). The AUR list is
    # pre-vetted — see SECURITY.md — so build without interactive prompts.
    yay -S --needed --noconfirm "$@" || exit 1
  else
    # Interactive: review each PKGBUILD/.install + upstream diff before building.
    yay -S --needed "$@" || exit 1
  fi
fi

for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
