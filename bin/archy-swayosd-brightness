#!/bin/bash

# archy:summary=Display brightness level using SwayOSD on the current monitor.
# archy:args=<0-100>
# archy:examples=archy swayosd brightness 0 | archy swayosd brightness 50 | archy swayosd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

archy-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "$(printf '%3d%%' "$percent")"
