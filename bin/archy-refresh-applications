#!/bin/bash

# archy:summary=Ensure all default .desktop, web apps, TUIs, and npm wrappers are installed.

mkdir -p ~/.local/share/icons/hicolor/48x48/apps/
cp ~/.local/share/archy/applications/icons/*.png ~/.local/share/icons/hicolor/48x48/apps/
gtk-update-icon-cache ~/.local/share/icons/hicolor &>/dev/null

# Copy .desktop declarations
mkdir -p ~/.local/share/applications
cp ~/.local/share/archy/applications/*.desktop ~/.local/share/applications/
cp ~/.local/share/archy/applications/hidden/*.desktop ~/.local/share/applications/

if archy-cmd-present alacritty; then
  cp ~/.local/share/archy/default/alacritty/alacritty.desktop ~/.local/share/applications/
fi

# Refresh the webapps, TUIs, and npm wrappers
bash $ARCHY_PATH/install/packaging/icons.sh
bash $ARCHY_PATH/install/packaging/webapps.sh
bash $ARCHY_PATH/install/packaging/tuis.sh
bash $ARCHY_PATH/install/packaging/npm.sh

update-desktop-database ~/.local/share/applications
