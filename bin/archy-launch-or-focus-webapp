#!/bin/bash

# archy:summary=Launch or focus on a given web app identified by the window-pattern.
# archy:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: archy-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="archy-launch-webapp $@"

exec archy-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
