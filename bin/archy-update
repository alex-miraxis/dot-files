#!/bin/bash

# archy:summary=Update Arch and system packages
# archy:args=[-y]
# archy:examples=archy update | archy update -y
# archy:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $ARCHY_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ARCHY_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/archy-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://github.com/alex-miraxis/dot-files/issues\033[0m"' ERR

if [[ $1 == "-y" ]] || archy-update-confirm; then
  archy-snapshot create || (($? == 127))
  archy-update-git
  archy-update-perform
fi
