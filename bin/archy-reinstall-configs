#!/bin/bash

# archy:summary=Reset all Arch user configs to the defaults
# archy:requires-sudo=true

set -e

# Overwrite all user configs with the Arch defaults.

if (( EUID == 0 )); then
  echo "Error: This script should not be run as root"
  exit 1
fi

echo "Resetting all Arch configs"
cp -R ~/.local/share/archy/config/* ~/.config/
cp ~/.local/share/archy/default/bashrc ~/.bashrc
echo '[[ -f ~/.bashrc ]] && . ~/.bashrc' | tee ~/.bash_profile >/dev/null

$(bash $ARCHY_PATH/install/config/theme.sh)

