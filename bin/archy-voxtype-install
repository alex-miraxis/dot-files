#!/bin/bash

# archy:summary=Install and configure Voxtype dictation
# archy:requires-sudo=true

set -e

# Install voxtype and configure it for use.

if gum confirm "Install Voxtype + AI model (~150MB) to enable dictation?"; then
  archy-pkg-add wtype voxtype-bin

  # Setup voxtype
  mkdir -p ~/.config/voxtype
  cp $ARCHY_PATH/default/voxtype/config.toml ~/.config/voxtype/

  voxtype setup --download --no-post-install
  if archy-hw-vulkan; then
    voxtype setup gpu --enable || true
  fi
  voxtype setup systemd

  archy-hyprland-toggle voxtype on
  archy-restart-waybar
  notify-send "    Voxtype Dictation Ready" "Hold F9 to dictate (or toggle with Super + Ctrl + X)." -t 10000
fi
