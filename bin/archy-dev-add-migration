#!/bin/bash

# archy:summary=Creates a new Arch migration named after the unix timestamp of the last commit.

cd ~/.local/share/archy
migration_file="$HOME/.local/share/archy/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ $1 != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
